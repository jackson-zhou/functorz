{
  "name": "functorz-miniapp-builder",
  "version": "0.1.0",
  "private": true,
  "description": "Schema-driven visual builder for Taro mini programs",
  "packageManager": "pnpm@10.18.3",
  "engines": {
    "node": ">=24.14.0",
    "pnpm": ">=10.18.3"
  },
  "scripts": {
    "build": "pnpm -r --if-present build",
    "dev": "pnpm --filter studio dev",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "pnpm -r --if-present test",
    "test:e2e": "pnpm --filter studio test:e2e",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "eslint": "9.39.4",
    "globals": "16.5.0",
    "prettier": "3.9.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.62.0"
  }
}
