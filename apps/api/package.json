    "@fastify/multipart": "9.3.0",
    "@fastify/rate-limit": "10.3.0",
    "@functorz/schema": "workspace:*",
    "bullmq": "5.58.5",
    "drizzle-orm": "0.44.7",
    "fastify": "5.8.5",
    "pg": "8.16.3"
  },
  "devDependencies": {
    "@types/node": "24.10.15",
    "@types/pg": "8.15.5",
    "drizzle-kit": "0.31.4",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "vitest": "4.1.9"
  }
}
