{
  "name": "runtime",
  "version": "0.1.0",
  "private": true,
  "description": "Schema-driven Taro runtime",
  "scripts": {
    "build": "pnpm --filter @functorz/schema build && pnpm --filter @functorz/runtime-renderer build && pnpm run build:h5 && pnpm run build:weapp",
    "build:h5": "taro build --type h5",
    "build:weapp": "taro build --type weapp",
    "dev:h5": "pnpm --filter @functorz/schema build && pnpm --filter @functorz/runtime-renderer build && taro build --type h5 --watch",
    "dev:weapp": "pnpm --filter @functorz/schema build && pnpm --filter @functorz/runtime-renderer build && taro build --type weapp --watch",
    "test": "node --import tsx --test src/status.test.ts",
    "typecheck": "tsc --noEmit --pretty false"
  },
  "browserslist": [
    "defaults and fully supports es6-module",
    "maintained node versions"
  ],
  "dependencies": {
    "@functorz/runtime-renderer": "workspace:*",
    "@functorz/schema": "workspace:*",
    "@babel/runtime": "7.29.7",
    "@tarojs/components": "4.2.0",
    "@tarojs/helper": "4.2.0",
    "@tarojs/plugin-framework-react": "4.2.0",
    "@tarojs/plugin-platform-alipay": "4.2.0",
    "@tarojs/plugin-platform-h5": "4.2.0",
    "@tarojs/plugin-platform-harmony-hybrid": "4.2.0",
    "@tarojs/plugin-platform-jd": "4.2.0",
    "@tarojs/plugin-platform-qq": "4.2.0",
    "@tarojs/plugin-platform-swan": "4.2.0",
    "@tarojs/plugin-platform-tt": "4.2.0",
    "@tarojs/plugin-platform-weapp": "4.2.0",
    "@tarojs/react": "4.2.0",
    "@tarojs/runtime": "4.2.0",
    "@tarojs/shared": "4.2.0",
    "@tarojs/taro": "4.2.0",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@babel/core": "7.29.7",
    "@babel/plugin-transform-class-properties": "7.25.9",
    "@babel/preset-react": "7.29.7",
    "@pmmmwh/react-refresh-webpack-plugin": "0.5.17",
    "@tarojs/cli": "4.2.0",
    "@tarojs/taro-loader": "4.2.0",
    "@tarojs/webpack5-runner": "4.2.0",
    "@types/minimatch": "5.1.2",
    "@types/node": "24.10.15",
    "@types/react": "18.3.31",
    "@types/webpack-env": "1.18.8",
    "babel-preset-taro": "4.2.0",
    "less": "4.5.1",
    "postcss": "8.5.15",
    "react-refresh": "0.14.2",
    "tsconfig-paths-webpack-plugin": "4.2.0",
    "tsx": "4.22.4",
    "typescript": "5.9.3",
    "webpack": "5.91.0"
  }
}
